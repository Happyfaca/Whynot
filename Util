    -- Собираем список мест, где ищем
    local containers = {replicated, workspace:FindFirstChild("Enemies")}
    
    for _, folder in ipairs(containers) do
        -- Вместо continue используем обычный if
        if folder then 
            for _, mob in pairs(folder:GetChildren()) do
                -- Проверка: жив ли моб и есть ли у него Humanoid
                local hum = mob:FindFirstChild("Humanoid")
                if mob:IsA("Model") and hum and hum.Health > 0 then
                    
                    local isMatch = false
                    if type(I) == "table" then
                        isMatch = table.find(I, mob.Name)
                    else
                        isMatch = (mob.Name == I)
                    end
                    
                    if isMatch then
                        return mob -- Возвращаем найденного моба
                    end
                end
            end
        end -- Закрываем проверку folder
