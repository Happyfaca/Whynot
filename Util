local function IsRaidMob(mob)
    local n = mob.Name:lower()

    if n:find("raid") or n:find("microchip") or n:find("island") then  
        return true  
    end  

    if mob:GetAttribute("IsRaid")  
        or mob:GetAttribute("RaidMob")  
        or mob:GetAttribute("IsBoss") then  
        return true  
    end  

    local hum = mob:FindFirstChild("Humanoid")  
    if hum and hum.WalkSpeed == 0 then  
        return true  
    end  

    if mob.Parent and tostring(mob.Parent):lower():find("_worldorigin") then  
        return true  
    end  

    return false
end

BringEnemy = function()
    if not PosMon or not _B then return end

    local lp = game.Players.LocalPlayer
    pcall(function()
        lp.SimulationRadius = math.huge -- Захватываем контроль над мобами
    end)

    local targetPos = PosMon
    local enemies = workspace.Enemies:GetChildren()

    for i = 1, #enemies do
        local mob = enemies[i]
        local m_root = mob:FindFirstChild("HumanoidRootPart")
        local m_hum = mob:FindFirstChild("Humanoid")

        if m_hum and m_root and m_hum.Health > 0 and not IsRaidMob(mob) then
            local dist = (m_root.Position - targetPos).Magnitude

            if dist <= (_G.BringRange or 250) then
                -- Отключаем столкновения (CanCollide), чтобы мобы не разлетались
                if not mob:GetAttribute("ZCol") then
                    for _, p in ipairs(mob:GetDescendants()) do
                        if p:IsA("BasePart") then p.CanCollide = false end
                    end
                    mob:SetAttribute("ZCol", true)
                end

                -- Сама магия стягивания
                m_root.Velocity = Vector3.zero
                m_root.CFrame = CFrame.new(targetPos)
                
                m_hum.WalkSpeed = 0
                m_hum.JumpPower = 0
                
                -- Если моб еще не зафиксирован - вешаем якорь
                if not m_root:FindFirstChild("ZinnerFix") then
                    local bv = Instance.new("BodyVelocity", m_root)
                    bv.Name = "ZinnerFix"
                    bv.Velocity = Vector3.zero
                    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                end
            end
        end
    end
end



