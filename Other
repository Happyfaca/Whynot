local HASH = "078da341"
local Net = game:GetService("ReplicatedStorage"):WaitForChild("Modules"):WaitForChild("Net")
local RegAttack = Net:WaitForChild("RE/RegisterAttack")
local RegHit = Net:WaitForChild("RE/RegisterHit")

local MOB_LIMIT = 3 -- 3 моба - это идеал (и притягивает, и урон 100% идет)
local ATTACK_SPEED = 0.05 -- Быстрая атака

--==================================================
-- ФУНКЦИЯ ПОИСКА ЦЕЛЕЙ (Берем тех, кто реально притянут)
--==================================================
function GetTargets()
    local t = {}
    local char = plr.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return t end
    
    local myPos = root.Position
    local enemies = workspace.Enemies:GetChildren()

    for i = 1, #enemies do
        local e = enemies[i]
        local r = e:FindFirstChild("HumanoidRootPart")
        if r and e:FindFirstChild("Humanoid") and e.Humanoid.Health > 0 then
            -- Если моб в радиусе удара (80)
            if (myPos - r.Position).Magnitude < 80 then
                table.insert(t, {e, r})
                if #t >= MOB_LIMIT then break end
            end
        end
    end
    return t
end

