-- Вспомогательные функции рейда
function IsIslandRaid(cu)
    local locs = workspace["_WorldOrigin"].Locations
    return locs:FindFirstChild("Island " .. cu)
end

function getNextIsland()
    local order = {5,4,3,2,1}
    for _, id in ipairs(order) do
        local island = IsIslandRaid(id)
        if island then
            -- Проверяем дистанцию, чтобы убедиться, что мы на этом острове
            local dist = (island.Position - plr.Character.HumanoidRootPart.Position).Magnitude
            if dist <= 4500 then
                return island
            end
        end
    end
end

-- Кэшируем ссылки
local RaidTimer = plr.PlayerGui.Main:WaitForChild("TopHUDList"):WaitForChild("RaidTimer")
local EnemiesFolder = workspace:WaitForChild("Enemies")

task.spawn(function()
    local checkTick = 0
    while task.wait(0.1) do
        if _G.Raiding then
            pcall(function()
                -- 1. Оптимизированная проверка таймера
                checkTick = checkTick + 1
                if checkTick % 10 == 0 then
                    if not RaidTimer.Visible then 
                        PosMon = nil
                        return 
                    end
                end

                local currentIsland = getNextIsland()
                if not currentIsland then return end

                -- 2. Сетевой контроль (важно для Xeno)
                if sethiddenproperty then
                    sethiddenproperty(plr, "SimulationRadius", 1500)
                elseif setsimulationradius then
                    setsimulationradius(1500)
                end

                local enemies = EnemiesFolder:GetChildren()
                if #enemies > 0 then
                    local targetMob = nil
                    
                    -- Ищем ПЕРВУЮ живую цель на поверхности
                    for _, m in ipairs(enemies) do
                        local hum = m:FindFirstChild("Humanoid")
                        local hrp = m:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and hum.Health > 0 and hrp.Position.Y > -100 then
                            targetMob = m
                            break 
                        end
                    end

                    if targetMob then
                        local m_root = targetMob.HumanoidRootPart
                        local p_root = plr.Character:FindFirstChild("HumanoidRootPart")
                        
                        if m_root and p_root then
                            PosMon = p_root.Position
                            
                            -- ЛОГИКА 5 ОСТРОВА (INSTANT KILL)
                            if _G.InstantClearLast and currentIsland.Name:find("5") then
                                -- Прилетаем вплотную для захвата физики
                                if (p_root.Position - m_root.Position).Magnitude > 25 then
                                    _tp(m_root.CFrame * cf_new(0, 15, 0))
                                    task.wait(0.05)
                                end
                                
                                -- Ресет моба в пустоту
                                m_root.CanCollide = false
                                m_root.Velocity = Vector3.new(0, -1000, 0)
                                m_root.CFrame = cf_new(m_root.Position.X, -1000, m_root.Position.Z)
                                
                                -- Помечаем для скрипта как мертвого
                                targetMob.Humanoid.Health = 0 
                            
                            -- ОБЫЧНЫЙ ФАРМ (Острова 1-4)
                            else
                                if (p_root.Position - m_root.Position).Magnitude > 20 then
                                    _tp(m_root.CFrame * cf_new(0, _G.MobHeight or 30, 0))
                                end
                                if G.Kill then G.Kill(targetMob, true) end
                            end
                        end
                    end
                else
                    -- Если остров пуст — отдыхаем в центре на высоте 70
                    local restPos = currentIsland.CFrame * cf_new(0, 70, 0)
                    if (plr.Character.HumanoidRootPart.Position - restPos.Position).Magnitude > 15 then
                        _tp(restPos)
                    end
                    PosMon = nil
                end
            end)
        end
    end
end)


