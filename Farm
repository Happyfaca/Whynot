                -- Используем ту самую countryCode
                TimeLabel:SetDesc(string.format("%02d/%02d/%04d - %02d:%02d:%02d %s [%s]", date.day, date.month, date.year, hour, date.min, date.sec, ampm, countryCode))
                
                local ut = math.floor(workspace.DistributedGameTime)
                ServerTimeLabel:SetDesc(string.format("%dh %dm %ds", math.floor(ut/3600), math.floor((ut%3600)/60), ut%60))

                -- 2. ТРЕХСЕКУНДНОЕ ОБНОВЛЕНИЕ
                if tickCounter % 3 == 0 then
                    local mirage = WorldLocs:FindFirstChild("Mirage Island") and "Mirage: ✅" or "Mirage: ❌"
                    local prehistoric = WorldLocs:FindFirstChild("Prehistoric Island") and "Pre: ✅" or "Pre: ❌"
