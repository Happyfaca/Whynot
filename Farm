local function FullSeaAttack(targetPos)
    local weapons = {"Melee", "Sword", "Blox Fruit", "Gun"}
    for _, wepType in ipairs(weapons) do
        pcall(function()
            weaponSc(wepType) 
            task.wait(0.05)
            local keys = {"Z", "X", "C", "V", "F"}
            for _, key in ipairs(keys) do
                if _G.SelectedSkills and _G.SelectedSkills[wepType] and _G.SelectedSkills[wepType][key] then
                    MousePos = targetPos
                    Useskills(wepType, key)
                    task.wait(0.1)
                end
            end
        end)
    end
end

-- [[ 2. ФУНКЦИЯ ПОИСКА ЦЕЛИ ]]
local function GetPriorityTarget()
    local char = plr.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position

    if workspace:FindFirstChild("SeaBeasts") then
        for _, sb in pairs(workspace.SeaBeasts:GetChildren()) do
            local sbHealth = sb:FindFirstChild("Health") or sb:FindFirstChildOfClass("Humanoid")
            local sbRoot = sb.PrimaryPart or sb:FindFirstChild("HumanoidRootPart")
            if sbRoot and sbHealth and (sbHealth.Value > 0 or (sbHealth:IsA("Humanoid") and sbHealth.Health > 0)) then
                if (myPos - sbRoot.Position).Magnitude < 4500 then
                    if sb.Name:find("Leviathan") and _G.Leviathan1 then return sb, "Levi" end
                    if (sb.Name:find("Sea Beast") or sb.Name:find("SeaBeast")) and _G.SeaBeast1 then return sb, "SB" end
                end
            end
        end
    end

    for _, enemy in pairs(workspace.Enemies:GetChildren()) do
        local name = enemy.Name
        local eRoot = enemy.PrimaryPart or enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Engine")
        if eRoot then
            local hp = 0
            local hum = enemy:FindFirstChildOfClass("Humanoid")
            local hVal = enemy:FindFirstChild("Health")
            if hum then hp = hum.Health 
            elseif hVal and (hVal:IsA("IntValue") or hVal:IsA("NumberValue")) then hp = hVal.Value end

            if hp > 0 then
                local dist = (myPos - eRoot.Position).Magnitude
                if dist < 4500 then
                    if _G.PGB and (name:find("Brigade") or name:find("Ship")) then return enemy, "Boat" end
                    if _G.FishBoat and (name:find("Fish") and name:find("Boat")) then return enemy, "Boat" end
                    if _G.TerrorShark and name == "Terrorshark" then return enemy, "Terror" end
                    if _G.Shark and name == "Shark" then return enemy, "Normal" end
                    if _G.Piranha and name == "Piranha" then return enemy, "Normal" end
                    if (_G.MobCrew or _G.HCM) and name:find("Crew") then return enemy, "Normal" end
                end
            end
        end
    end
    return nil
end

