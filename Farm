            -- === ПРИОРИТЕТ 2: ВРАГИ (БОЙ) ===
            if currentEnemy then
                if currentBoat and currentBoat:FindFirstChild("VehicleSeat") then
                    currentBoat.VehicleSeat.Anchored = true
                    if hum.Sit then hum.Sit = false; task.wait(0.1); root.CFrame = root.CFrame * cf_n(0, 50, 0) end
